---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Icon from '../../components/Icon.astro';

export async function getStaticPaths() {
  const all = (await getCollection('products')).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
  );
  // Only collection entries join the prev/next walk; radar entries stand alone.
  const collection = all.filter((p) => p.data.status === 'collection');
  const collectionPaths = collection.map((p, i) => ({
    params: { id: p.id },
    props: {
      product: p,
      // the walk moves top-to-bottom through the index: newer piece ← current → older piece
      prev: i > 0 ? { id: collection[i - 1].id, name: collection[i - 1].data.name } : null,
      next: i < collection.length - 1 ? { id: collection[i + 1].id, name: collection[i + 1].data.name } : null,
    },
  }));
  const radarPaths = all
    .filter((p) => p.data.status === 'radar')
    .map((p) => ({
      params: { id: p.id },
      props: { product: p, prev: null, next: null },
    }));
  return [...collectionPaths, ...radarPaths];
}

const { product, prev, next } = Astro.props;
const { Content } = await render(product);
const d = product.data;
const dateLabel = d.date.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
const dims = d.scores
  ? [
      { label: 'Craft', value: d.scores.craft },
      { label: 'Originality', value: d.scores.originality },
      { label: 'Technology', value: d.scores.tech },
    ]
  : [];

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: d.name,
  url: d.url,
  applicationCategory: d.category,
  operatingSystem: d.platform.join(', '),
  description: d.tagline,
  ...(d.image ? { image: new URL(d.image, Astro.site).href } : {}),
  review: {
    '@type': 'Review',
    author: { '@type': 'Organization', name: 'Considered' },
    reviewBody: d.review.join('\n\n'),
  },
});
---

<Base
  title={`${d.name} — Considered`}
  description={d.tagline}
  ogImage={d.image}
  ogType="article"
>
  <script type="application/ld+json" set:html={jsonLd} />
  <a href="/#index" class="back"><Icon name="arrow-left" /> Back to index</a>

  <header class="product-head">
    {d.status === 'radar' && <p class="product-cat">On the radar</p>}
    <h1 transition:name={`name-${product.id}`}>{d.name}</h1>
    <p class="product-tagline">{d.tagline}</p>
  </header>

  <dl class="meta-table">
    <div>
      <dt><Icon name="shapes" /> Category</dt>
      <dd>{d.category}</dd>
    </div>
    <div>
      <dt><Icon name="devices" /> Platform</dt>
      <dd>{d.platform.join(' · ')}</dd>
    </div>
    <div>
      <dt><Icon name="tag" /> Pricing</dt>
      <dd>{d.pricing}</dd>
    </div>
    {
      d.tags.length > 0 && (
        <div>
          <dt><Icon name="sparkles" /> Good for</dt>
          <dd class="meta-tags">
            {d.tags.map((t) => (
              <span class="tag">{t}</span>
            ))}
          </dd>
        </div>
      )
    }
    <div>
      <dt><Icon name="link" /> Link</dt>
      <dd>
        <a href={d.url} target="_blank" rel="noopener">{new URL(d.url).hostname} <Icon name="arrow-up-right" /></a>
      </dd>
    </div>
    <div>
      <dt><Icon name="calendar" /> Added</dt>
      <dd>{dateLabel}</dd>
    </div>
  </dl>

  {
    d.image && (
      <figure class="product-shot">
        <img
          src={d.image}
          alt={`${d.name} — product visual`}
          width="1200"
          height="630"
          loading="eager"
          transition:name={`shot-${product.id}`}
        />
      </figure>
    )
  }

  {
    dims.length > 0 && (
      <section class="dims">
        <div class="section-label">
          <span>Where it shines</span>
        </div>
        <div class="dims-rows">
          {dims.map((dim) => (
            <div class="dim">
              <span class="dim-label">{dim.label}</span>
              <span class="dim-scale" aria-label={`${dim.label}: ${dim.value} of 5`}>
                {[1, 2, 3, 4, 5].map((n) => (
                  <span class={n <= dim.value ? 'seg on' : 'seg'} />
                ))}
              </span>
            </div>
          ))}
        </div>
      </section>
    )
  }

  <section class="why">
    <div class="section-label">
      <span>{d.status === 'radar' ? "Why I'm watching" : "Editor's notes"}</span>
    </div>
    <blockquote>
      {d.review.map((para) => <p>{para}</p>)}
    </blockquote>
  </section>

  <section class="facts">
    <div class="section-label">
      <span>At a glance</span>
    </div>
    <div class="prose">
      <Content />
    </div>
  </section>

  {
    d.status === 'collection' && (
      <nav class="entry-nav" aria-label="Walk the collection">
        {prev ? (
          <a href={`/p/${prev.id}/`} class="entry-nav-cell">
            <span class="entry-nav-label"><Icon name="arrow-left" /> Newer</span>
            <span class="entry-nav-name">{prev.name}</span>
          </a>
        ) : (
          <span class="entry-nav-cell entry-nav-end">
            <span class="entry-nav-label">You're at the newest piece</span>
          </span>
        )}
        {next ? (
          <a href={`/p/${next.id}/`} class="entry-nav-cell entry-nav-next">
            <span class="entry-nav-label">Older <Icon name="arrow-right" /></span>
            <span class="entry-nav-name">{next.name}</span>
          </a>
        ) : (
          <span class="entry-nav-cell entry-nav-next entry-nav-end">
            <span class="entry-nav-label">That's the whole collection — for now</span>
          </span>
        )}
      </nav>
    )
  }
</Base>
