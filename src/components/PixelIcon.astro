---
// 像素风小图标（12×12 网格，方块填充）——用于评分 pips，whimsically.app 风格
interface Props {
  name: string;
}

const { name } = Astro.props;

const icons: Record<string, string> = {
  // 宝石：块状钻石
  gem: '<rect x="3" y="1" width="6" height="2"/><rect x="1" y="3" width="10" height="2"/><rect x="2" y="5" width="8" height="2"/><rect x="4" y="7" width="4" height="2"/><rect x="5" y="9" width="2" height="2"/>',
  // 灯泡：圆顶 + 灯座
  bulb: '<rect x="4" y="0" width="4" height="1"/><rect x="3" y="1" width="6" height="4"/><rect x="4" y="5" width="4" height="2"/><rect x="4" y="8" width="4" height="1"/><rect x="5" y="10" width="2" height="1"/>',
  // 芯片：主体挖芯 + 四向引脚
  chip: '<rect x="3" y="3" width="6" height="1"/><rect x="3" y="8" width="6" height="1"/><rect x="3" y="4" width="1" height="4"/><rect x="8" y="4" width="1" height="4"/><rect x="5" y="5" width="2" height="2"/><rect x="4" y="1" width="1" height="1"/><rect x="7" y="1" width="1" height="1"/><rect x="4" y="10" width="1" height="1"/><rect x="7" y="10" width="1" height="1"/><rect x="1" y="4" width="1" height="1"/><rect x="1" y="7" width="1" height="1"/><rect x="10" y="4" width="1" height="1"/><rect x="10" y="7" width="1" height="1"/>',
};
---

<svg
  class="pixel-ico"
  viewBox="0 0 12 12"
  fill="currentColor"
  shape-rendering="crispEdges"
  aria-hidden="true"
  set:html={icons[name]}
/>
