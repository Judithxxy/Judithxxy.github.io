---
// Hero illustration: an exploded technical drawing of an abstract "product".
// Parts float apart for inspection; one is circled in vermilion — the chosen one.
// Royal blue line work on platinum, mono annotations. pointer-events: none.
---

<svg
  class="hero-art"
  viewBox="0 0 520 600"
  fill="none"
  aria-hidden="true"
>
  <g stroke="var(--blue)" stroke-width="1.5">
    <!-- central exploded axis -->
    <line x1="260" y1="16" x2="260" y2="584" stroke-dasharray="2 7" stroke-width="1" opacity="0.55" />

    <!-- part A · lens/disc -->
    <g>
      <ellipse cx="260" cy="70" rx="88" ry="26" fill="var(--paper-deep)" />
      <ellipse cx="260" cy="70" rx="46" ry="13" />
      <ellipse cx="260" cy="70" rx="14" ry="4.5" />
    </g>

    <!-- part B · interface plate -->
    <g>
      <rect x="150" y="160" width="220" height="128" rx="10" fill="var(--paper-deep)" />
      <line x1="172" y1="192" x2="308" y2="192" />
      <line x1="172" y1="216" x2="348" y2="216" opacity="0.6" />
      <line x1="172" y1="238" x2="272" y2="238" opacity="0.6" />
      <circle cx="340" cy="262" r="9" />
    </g>

    <!-- part C · the chip (the chosen one) -->
    <g>
      <rect x="212" y="352" width="96" height="96" rx="8" fill="var(--paper-deep)" />
      <rect x="238" y="378" width="44" height="44" rx="4" />
      <g stroke-width="1.25">
        <line x1="228" y1="340" x2="228" y2="352" /><line x1="252" y1="340" x2="252" y2="352" />
        <line x1="276" y1="340" x2="276" y2="352" /><line x1="292" y1="340" x2="292" y2="352" />
        <line x1="228" y1="448" x2="228" y2="460" /><line x1="252" y1="448" x2="252" y2="460" />
        <line x1="276" y1="448" x2="276" y2="460" /><line x1="292" y1="448" x2="292" y2="460" />
        <line x1="200" y1="368" x2="212" y2="368" /><line x1="200" y1="392" x2="212" y2="392" />
        <line x1="200" y1="416" x2="212" y2="416" /><line x1="200" y1="434" x2="212" y2="434" />
        <line x1="308" y1="368" x2="320" y2="368" /><line x1="308" y1="392" x2="320" y2="392" />
        <line x1="308" y1="416" x2="320" y2="416" /><line x1="308" y1="434" x2="320" y2="434" />
      </g>
    </g>

    <!-- part D · base plate -->
    <g>
      <rect x="136" y="512" width="248" height="52" rx="8" fill="var(--paper-deep)" />
      <circle cx="160" cy="538" r="4" /><circle cx="360" cy="538" r="4" />
      <line x1="196" y1="538" x2="324" y2="538" opacity="0.5" />
    </g>

    <!-- leader lines -->
    <g stroke-width="1" opacity="0.7">
      <line x1="348" y1="70" x2="428" y2="70" />
      <line x1="370" y1="224" x2="452" y2="224" />
      <line x1="384" y1="538" x2="452" y2="538" />
    </g>

    <!-- dimension ticks, left side -->
    <g stroke-width="1" opacity="0.6">
      <line x1="96" y1="160" x2="96" y2="288" />
      <line x1="88" y1="160" x2="104" y2="160" />
      <line x1="88" y1="288" x2="104" y2="288" />
    </g>
  </g>

  <!-- the vermilion selection: hand-drawn circle around the chip -->
  <g stroke="var(--accent)" fill="none">
    <path
      stroke-width="2"
      stroke-linecap="round"
      d="M 262 322 C 348 328 366 372 358 410 C 350 462 296 486 250 480 C 192 472 162 434 170 392 C 178 348 224 326 274 328"
    />
    <path stroke-width="1.5" stroke-linecap="round" d="M 344 452 L 396 496" />
  </g>

  <!-- annotations -->
  <g fill="var(--ink-faint)" font-family="IBM Plex Mono, monospace" font-size="11">
    <text x="434" y="74">fig. A</text>
    <text x="458" y="228">fig. B</text>
    <text x="458" y="542">fig. D</text>
    <text x="402" y="514" fill="var(--accent)">considered.</text>
  </g>

  <!-- registration marks -->
  <g fill="var(--ink-faint)" font-family="IBM Plex Mono, monospace" font-size="13">
    <text x="20" y="30">+</text>
    <text x="492" y="30">+</text>
    <text x="20" y="588">+</text>
    <text x="492" y="588">+</text>
  </g>
</svg>
