---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Icon from './Icon.astro';
import { t, collectionFor, LOCALES, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const s = t[locale];
const prefix = LOCALES.find((l) => l.code === locale)!.prefix;

const all = (await getCollection(collectionFor[locale])).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const products = all.filter((p) => p.data.status === 'collection');
const radar = all.filter((p) => p.data.status === 'radar');
const latest = products[0];
const fullStop = locale === 'en' ? '.' : '。';

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Considered',
  url: Astro.site?.href,
  description: s.metaDescription,
});
---

<Base
  title={`Considered — ${locale === 'en' ? 'only AI products made with care' : locale === 'zh' ? '只收用心打磨的 AI 产品' : '丁寧に作られたAIプロダクトだけを'}`}
  description={s.metaDescription}
  locale={locale}
  pagePath="/"
>
  <script type="application/ld+json" set:html={jsonLd} />
  <section class="hero">
    <h1 class="reveal" style="--i: 0">
      {s.heroTitleA}<br />{s.heroTitleB}<span class="full-stop">{fullStop}</span>
    </h1>
    <p class="hero-sub reveal" style="--i: 1">{s.heroSub}</p>
    <p class="hero-count reveal" style="--i: 2">
      {s.currently}<strong>{products.length}</strong>{s.entries}{
        radar.length > 0 && <span class="hero-radar"> · {radar.length} {s.onRadarCount}</span>
      }
    </p>
    <span class="hero-mark" aria-hidden="true">{s.heroMark}</span>
  </section>

  <section class="criteria" id="criteria">
    <div>
      <h2 set:html={s.criteriaLooksFor} />
      <ul>
        <li>{s.lf1}</li>
        <li>{s.lf2}</li>
        <li>{s.lf3}</li>
        <li>{s.lf4}</li>
      </ul>
    </div>
    <div>
      <h2>{s.criteriaPasses}</h2>
      <ul>
        <li>{s.po1}</li>
        <li>{s.po2}</li>
        <li>{s.po3}</li>
        <li>{s.po4}</li>
      </ul>
    </div>
  </section>

  {
    latest && (
      <section class="featured reveal" style="--i: 3">
        <div class="section-label">
          <span>{s.latestAddition}</span>
          <span class="note">{latest.data.category}</span>
        </div>
        <a href={`${prefix}/p/${latest.id}/`} class="featured-link">
          <div class="featured-main">
            <h2 class="featured-name">{latest.data.name}</h2>
            <p class="featured-tagline">{latest.data.tagline}</p>
            {latest.data.image && (
              <figure class="featured-shot">
                <img
                  src={latest.data.image}
                  alt={`${latest.data.name} — product visual`}
                  width="1200"
                  height="630"
                  loading="eager"
                />
              </figure>
            )}
            <p class="featured-cta">{s.editorsNotesCta} <Icon name="arrow-right" /></p>
          </div>
          <blockquote class="featured-quote">
            <p>“{latest.data.highlight ?? latest.data.review[0]}”</p>
          </blockquote>
        </a>
      </section>
    )
  }

  <section id="index">
    <div class="index-head">
      <h2>{s.index}</h2>
    </div>
    <ol class="entries">
      {
        products.map((p, i) => (
          <li class="entry reveal" style={`--i: ${i + 4}`}>
            <a href={`${prefix}/p/${p.id}/`}>
              <span class="entry-main">
                {p.data.image && (
                  <span class="entry-thumb">
                    <img
                      src={p.data.image}
                      alt=""
                      width="1200"
                      height="630"
                      loading="lazy"
                      transition:name={`shot-${p.id}`}
                    />
                  </span>
                )}
                <span class="entry-text">
                  <span class="entry-name" transition:name={`name-${p.id}`}>{p.data.name}</span>
                  {p.data.tags.length > 0 && (
                    <span class="entry-tags">
                      {p.data.tags.map((tag) => (
                        <span class="tag">{tag}</span>
                      ))}
                    </span>
                  )}
                </span>
              </span>
              <span class="entry-verdict">“{p.data.verdict}”</span>
              <span class="entry-arrow" aria-hidden="true"><Icon name="arrow-right" /></span>
            </a>
          </li>
        ))
      }
    </ol>
  </section>

  {
    radar.length > 0 && (
      <section id="radar">
        <div class="index-head">
          <h2><Icon name="radar" /> {s.onTheRadar}</h2>
          <p class="radar-note">{s.radarNote}</p>
        </div>
        <ol class="radar-list">
          {radar.map((p) => (
            <li class="radar-entry">
              <a href={`${prefix}/p/${p.id}/`}>
                <span class="radar-name" transition:name={`name-${p.id}`}>
                  {p.data.favicon && <img class="prod-ico" src={p.data.favicon} alt="" loading="lazy" />}
                  {p.data.name}
                </span>
                <span class="radar-meta">{p.data.category}</span>
                <span class="radar-verdict">{p.data.verdict}</span>
                <span class="entry-arrow" aria-hidden="true"><Icon name="arrow-right" /></span>
              </a>
            </li>
          ))}
        </ol>
      </section>
    )
  }
</Base>
