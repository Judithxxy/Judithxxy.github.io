---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Icon from './Icon.astro';
import Manifesto from './Manifesto.astro';
import TextWave from './TextWave.astro';
import HeroLines from './HeroLines.astro';
import HeroDots from './HeroDots.astro';
import { t, collectionFor, LOCALES, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const s = t[locale];
const prefix = LOCALES.find((l) => l.code === locale)!.prefix;

const all = (await getCollection(collectionFor[locale])).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const products = all.filter((p) => p.data.status === 'collection');
const radar = all.filter((p) => p.data.status === 'radar');
// 卡片架：最新 5 件，Aave 式扇形摊放
const shelf = products.slice(0, 5);
const fullStop = locale === 'en' ? '.' : '。';

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Considered',
  url: Astro.site?.href,
  description: s.metaDescription,
});
---

<Base
  title={`Considered — ${locale === 'en' ? 'only AI products made with care' : locale === 'zh' ? '只收用心打磨的 AI 产品' : '丁寧に作られたAIプロダクトだけを'}`}
  description={s.metaDescription}
  ogImage="/images/og-home.png"
  locale={locale}
  pagePath="/"
>
  <script type="application/ld+json" set:html={jsonLd} />
  <section class="hero">
    <HeroDots />
    <HeroLines />
    <h1 class="reveal" style="--i: 0">
      {s.heroTitleA}<br /><span class="h1-blue">{s.heroTitleB}</span><span class="full-stop">{fullStop}</span>
    </h1>
    <p class="hero-sub reveal" style="--i: 1">{s.heroSub}</p>
    <p class="hero-count reveal" style="--i: 2">
      {s.countLine.replace('{n}', String(products.length)).replace('{m}', String(radar.length))}
    </p>
  </section>

  <Manifesto locale={locale} />

  <TextWave />

  <section class="shelf" aria-label={s.latestAddition}>
    <div class="index-head">
      <h2>{s.latestAddition}</h2>
    </div>
    <ol class="cards">
      {
        shelf.map((p) => (
          <li class="card">
            <a href={`${prefix}/p/${p.id}/`}>
              {p.data.image ? (
                <span class="card-shot">
                  <img
                    src={p.data.image}
                    alt=""
                    width="1200"
                    height="630"
                    loading="lazy"
                    transition:name={`shot-${p.id}`}
                  />
                </span>
              ) : (
                <span class="card-shot card-shot--empty">
                  {p.data.favicon && <img src={p.data.favicon} alt="" loading="lazy" />}
                </span>
              )}
              <span class="card-name" transition:name={`name-${p.id}`}>
                {p.data.favicon && <img class="prod-ico" src={p.data.favicon} alt="" loading="lazy" />}
                {p.data.name}
              </span>
              <span class="card-verdict">“{p.data.verdict}”</span>
            </a>
          </li>
        ))
      }
    </ol>
  </section>

  <section id="index">
    <div class="index-head">
      <h2>{s.index}</h2>
    </div>
    <ol class="catalog">
      {
        products.map((p) => (
          <li class="catalog-row">
            <a href={`${prefix}/p/${p.id}/`}>
              {p.data.favicon && <img class="prod-ico" src={p.data.favicon} alt="" loading="lazy" />}
              <span class="catalog-name">{p.data.name}</span>
              <span class="catalog-tagline">{p.data.tagline}</span>
              <span class="entry-arrow" aria-hidden="true"><Icon name="arrow-right" /></span>
            </a>
          </li>
        ))
      }
    </ol>
  </section>

  <script is:inline data-astro-rerun>
    // 卡片架发牌入场：进入视野时从叠放态旋开摊平（大屏 + 允许动效时才启用）
    (() => {
      const cards = document.querySelector('.cards');
      if (!cards) return;
      if (window.__dealCheck) {
        window.removeEventListener('scroll', window.__dealCheck);
        window.__dealCheck = null;
      }
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const wide = window.matchMedia('(min-width: 64rem)').matches;
      if (reduced || !wide) {
        cards.classList.add('dealt');
        return;
      }
      cards.classList.add('will-deal');
      const check = () => {
        if (cards.getBoundingClientRect().top < window.innerHeight * 0.82) {
          cards.classList.remove('will-deal');
          cards.classList.add('dealt');
          window.removeEventListener('scroll', check);
          window.__dealCheck = null;
        }
      };
      window.__dealCheck = check;
      window.addEventListener('scroll', check, { passive: true });
      check();
    })();
  </script>

  {
    radar.length > 0 && (
      <section id="radar">
        <div class="index-head">
          <h2><Icon name="radar" /> {s.onTheRadar}</h2>
          <p class="radar-note">{s.radarNote}</p>
        </div>
        <ol class="radar-list">
          {radar.map((p) => (
            <li class="radar-entry">
              <a href={`${prefix}/p/${p.id}/`}>
                <span class="radar-name" transition:name={`name-${p.id}`}>
                  {p.data.favicon && <img class="prod-ico" src={p.data.favicon} alt="" loading="lazy" />}
                  {p.data.name}
                </span>
                <span class="radar-meta">{p.data.category}</span>
                <span class="radar-verdict">{p.data.verdict}</span>
                <span class="entry-arrow" aria-hidden="true"><Icon name="arrow-right" /></span>
              </a>
            </li>
          ))}
        </ol>
      </section>
    )
  }
</Base>
