---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Icon from './Icon.astro';
import StickerField from './StickerField.astro';
import { t, collectionFor, LOCALES, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const s = t[locale];
const prefix = LOCALES.find((l) => l.code === locale)!.prefix;

const all = (await getCollection(collectionFor[locale])).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const products = all.filter((p) => p.data.status === 'collection');
const radar = all.filter((p) => p.data.status === 'radar');
// 标本卡：最新 6 件正式收录
const shelf = products.slice(0, 6);

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Actually Good',
  url: Astro.site?.href,
  description: s.metaDescription,
});
---

<Base
  title={`Actually Good — ${locale === 'en' ? 'AI products that get something right' : locale === 'zh' ? '收录真正有品位的 AI 产品' : '「うまく作られた」AIプロダクトだけを'}`}
  description={s.metaDescription}
  ogImage="/images/og-home.png"
  locale={locale}
  pagePath="/"
>
  <script type="application/ld+json" set:html={jsonLd} />
  <section class="hero">
    <h1>
      {s.heroTitleA}<br />{s.heroMarkPre}<span class="mark">{s.heroMarkText}</span>{s.heroMarkPost}<span
        class="full-stop">{locale === 'en' ? '.' : '。'}</span>
    </h1>
    <p class="hero-sub">{s.heroSub}</p>
    <StickerField locale={locale} productCount={products.length} radarCount={radar.length} />
  </section>


  <section class="shelf" aria-label={s.latestAddition}>
    <ol class="cards">
      {
        shelf.map((p) => (
          <li class="card">
            <span class="tape" aria-hidden="true" />
            <a href={`${prefix}/p/${p.id}/`}>
              {p.data.image ? (
                <span class="card-shot">
                  <img
                    src={p.data.image}
                    alt=""
                    width="1200"
                    height="630"
                    loading="lazy"
                    transition:name={`shot-${p.id}`}
                  />
                </span>
              ) : (
                <span class="card-shot card-shot--empty">
                  {p.data.favicon && <img src={p.data.favicon} alt="" loading="lazy" />}
                </span>
              )}
              <span class="card-name" transition:name={`name-${p.id}`}>
                {p.data.favicon && <img class="prod-ico" src={p.data.favicon} alt="" loading="lazy" />}
                {p.data.name}
              </span>
              <span class="card-verdict">“{p.data.verdict}”</span>
            </a>
          </li>
        ))
      }
    </ol>
  </section>

  <section id="index">
    <div class="index-head">
      <h2>{s.index}</h2>
    </div>
    <ol class="catalog">
      <li class="catalog-group" aria-hidden="true">{s.groupPioneers}</li>
      {
        products.map((p) => (
          <li class="catalog-row">
            <a href={`${prefix}/p/${p.id}/`}>
              <span class="catalog-name" transition:name={`name-${p.id}`}>
                {p.data.favicon && <img class="prod-ico" src={p.data.favicon} alt="" loading="lazy" />}
                {p.data.name}
              </span>
              <span class="catalog-tagline">{p.data.tagline}</span>
              <span class="entry-arrow" aria-hidden="true"><Icon name="arrow-right" /></span>
            </a>
          </li>
        ))
      }
      <li class="catalog-group" aria-hidden="true">{s.onTheRadar}</li>
      {
        radar.map((p) => (
          <li class="catalog-row">
            <a href={`${prefix}/p/${p.id}/`}>
              <span class="catalog-name" transition:name={`name-${p.id}`}>
                {p.data.favicon && <img class="prod-ico" src={p.data.favicon} alt="" loading="lazy" />}
                {p.data.name}
              </span>
              <span class="catalog-tagline">{p.data.tagline}</span>
              <span class="entry-arrow" aria-hidden="true"><Icon name="arrow-right" /></span>
            </a>
          </li>
        ))
      }
    </ol>
  </section>

  <script is:inline data-astro-rerun>
    // 标本卡入场：进入视野时逐张落纸
    (() => {
      const cards = document.querySelector('.cards');
      if (!cards) return;
      if (window.__settleCheck) {
        window.removeEventListener('scroll', window.__settleCheck);
        window.__settleCheck = null;
      }
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      cards.classList.add('will-settle');
      const check = () => {
        if (cards.getBoundingClientRect().top < window.innerHeight * 0.85) {
          cards.classList.remove('will-settle');
          cards.classList.add('on');
          window.removeEventListener('scroll', check);
          window.__settleCheck = null;
        }
      };
      window.__settleCheck = check;
      window.addEventListener('scroll', check, { passive: true });
      check();
    })();
  </script>
</Base>
