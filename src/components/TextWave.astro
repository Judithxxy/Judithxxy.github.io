---
// 宣言 → 卡片架的过渡带 —— Originkit「Text Path」的移植：
// 文字沿正弦波无限滚动的跑马灯。保留原组件的核心机制：
// 波形路径向两侧多铺半个周期（永不露出端点）、textPath 的 startOffset
// 按「文字+分隔符」一个重复单元取模回绕（接缝逐像素一致）、
// (4 单元 − 2 单元)/2 的测量法消除 SVG 首尾空白裁剪误差。
// 改动：React 壳剥掉、文案 Considered.、配色字体接入主题。
---

<div class="text-wave" aria-hidden="true">
  <svg class="tw-svg" preserveAspectRatio="xMidYMid meet">
    <defs>
      <path id="tw-path" fill="none"></path>
    </defs>
    <text class="tw-font tw-measure tw-m2" x="0" y="-9999"></text>
    <text class="tw-font tw-measure tw-m4" x="0" y="-9999"></text>
    <text class="tw-font tw-text">
      <textPath class="tw-tp" href="#tw-path"></textPath>
    </text>
  </svg>
</div>

<script is:inline data-astro-rerun>
  (() => {
    const wrap = document.querySelector('.text-wave');
    if (!wrap) return;
    if (window.__textWaveStop) window.__textWaveStop();

    const svg = wrap.querySelector('.tw-svg');
    const pathEl = wrap.querySelector('#tw-path');
    const m2 = wrap.querySelector('.tw-m2');
    const m4 = wrap.querySelector('.tw-m4');
    const tp = wrap.querySelector('.tw-tp');
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // 原组件默认值：speed 30（×5 = 150px/s）、reversed、频率 3、波高 100
    const TEXT = 'Considered.';
    const SEP = '   •   '; // NBSP：SVG 会折叠普通空格
    const FONT_SIZE = 17;
    const PPS = 30 * 5;
    const DIR = 1; // reversed: true
    const WAVE_FREQ = 2;
    const WAVE_HEIGHT = 48;

    const unitText = TEXT + SEP;
    let unitWidth = 0;
    let offset = 0;

    const build = () => {
      const r = wrap.getBoundingClientRect();
      const w = Math.max(1, Math.round(r.width));
      const h = Math.max(1, Math.round(r.height));
      svg.setAttribute('viewBox', `0 0 ${w} ${h}`);

      // 正弦波：振幅收在容器内（波峰处字形还要占一个字号的余量），
      // 贝塞尔控制点 ×4/3 让渲染峰值精确等于振幅
      const cy = h / 2;
      const amplitude = Math.max(0, Math.min(WAVE_HEIGHT / 2, h / 2 - FONT_SIZE));
      const ctrlAmp = amplitude * (4 / 3);
      const halfCycles = Math.max(1, Math.round(WAVE_FREQ * 2));
      const halfWidth = w / halfCycles;
      const overflow = Math.max(100, w * 0.3);
      const leftSteps = Math.ceil(overflow / halfWidth);
      const rightSteps = Math.ceil(overflow / halfWidth);
      const totalSteps = halfCycles + leftSteps + rightSteps;
      const xStart = -leftSteps * halfWidth;
      const startSign = leftSteps % 2 === 0 ? -1 : 1;

      let d = `M ${xStart},${cy}`;
      for (let i = 0; i < totalSteps; i++) {
        const xa = xStart + i * halfWidth;
        const xb = xStart + (i + 1) * halfWidth;
        const peakY = cy + (i % 2 === 0 ? startSign * ctrlAmp : -startSign * ctrlAmp);
        d += ` C ${xa + halfWidth / 3},${peakY} ${xb - halfWidth / 3},${peakY} ${xb},${cy}`;
      }
      pathEl.setAttribute('d', d);

      // 单元周期 = (4 单元长 − 2 单元长) / 2，抵消首尾空白裁剪
      m2.textContent = unitText.repeat(2);
      m4.textContent = unitText.repeat(4);
      let period = 0;
      try {
        period = (m4.getComputedTextLength() - m2.getComputedTextLength()) / 2;
      } catch { period = 0; }
      unitWidth = period > 0 && isFinite(period)
        ? period
        : unitText.length * FONT_SIZE * 0.6;

      // 重复次数：覆盖路径全长（弧长估算取大，避免尾段空白）
      let pathLen = 0;
      try { pathLen = pathEl.getTotalLength(); } catch { pathLen = 0; }
      const segArc = 2 * Math.hypot(halfWidth / 2, ctrlAmp) * 1.15;
      const estLen = totalSteps * Math.max(halfWidth, segArc);
      const effLen = Math.max(pathLen, estLen);
      const repeatCount = Math.min(256, Math.max(2, Math.ceil(effLen / unitWidth) + 3));
      tp.textContent = unitText.repeat(repeatCount);
    };

    build();
    // 字体加载完成后重测（Instrument Sans 到位前的测量会偏差，导致回绕跳动）
    if (document.fonts && document.fonts.ready) {
      document.fonts.ready.then(build);
    }

    if (reduced) {
      tp.setAttribute('startOffset', '0');
      const onResizeStatic = () => build();
      window.addEventListener('resize', onResizeStatic, { passive: true });
      window.__textWaveStop = () => {
        window.removeEventListener('resize', onResizeStatic);
        window.__textWaveStop = null;
      };
      return;
    }

    let raf = 0;
    let lastT = null;
    const loop = (t) => {
      raf = requestAnimationFrame(loop);
      if (lastT == null) lastT = t;
      const dt = Math.min((t - lastT) / 1000, 1 / 30); // dt 钳制，卡顿不跳位
      lastT = t;
      if (unitWidth <= 0) return;
      const rect = wrap.getBoundingClientRect();
      if (rect.bottom < 0 || rect.top > window.innerHeight) return; // 滚出视野暂停
      offset += DIR * PPS * dt;
      offset -= Math.floor(offset / unitWidth) * unitWidth; // [0, unit) 无缝回绕
      tp.setAttribute('startOffset', `${offset}px`);
    };
    raf = requestAnimationFrame(loop);

    let resizePending = false;
    const onResize = () => {
      if (resizePending) return;
      resizePending = true;
      requestAnimationFrame(() => {
        resizePending = false;
        build();
      });
    };
    window.addEventListener('resize', onResize, { passive: true });

    window.__textWaveStop = () => {
      cancelAnimationFrame(raf);
      window.removeEventListener('resize', onResize);
      window.__textWaveStop = null;
    };
  })();
</script>
