---
// The publication's manifesto: six sentences, large type, one at a time,
// slow scroll reveal. No explanations underneath — the belief carries itself.
import { manifesto, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const lines = manifesto[locale];
---

<section class="manifesto" id="manifesto" aria-label="Manifesto">
  {lines.map((line) => <p class="manifesto-line" set:html={line} />)}
</section>

<script is:inline data-astro-rerun>
  // Apple Music 歌词式：未读的句子是灰的，滚过"阅读线"（视口 62%）逐句点亮成蓝
  (function () {
    var lines = Array.prototype.slice.call(document.querySelectorAll('.manifesto-line'));
    if (!lines.length) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      lines.forEach(function (el) { el.classList.add('lit'); });
      return;
    }
    function check() {
      var readingLine = window.innerHeight * 0.62;
      lines.forEach(function (el) {
        var r = el.getBoundingClientRect();
        if (r.top < readingLine) {
          el.classList.add('lit');
        } else {
          el.classList.remove('lit');
        }
      });
    }
    if (window.__maniCheck) window.removeEventListener('scroll', window.__maniCheck);
    window.__maniCheck = check;
    window.addEventListener('scroll', check, { passive: true });
    check();
  })();
</script>
