---
// Hero 背景线稿：界面线框（interfacecraft 黑卡式的面板图），
// 加载时线条按 stroke-dashoffset 依次画出，画完后留一颗闪烁的光标像素。
// 底纹由 HeroDots 的动态点阵承担。纯内联 SVG，无位图、无运行时 JS。
---

<div class="hero-lines" aria-hidden="true">
  <svg viewBox="0 0 720 440" preserveAspectRatio="xMaxYMid meet" fill="none">
    <g class="hl-draw" stroke-linecap="round">
      <rect class="hl-line hl-w15" pathLength="1" x="64" y="56" width="592" height="328" rx="28" style="--d: 0.1s" />
      <rect class="hl-line" pathLength="1" x="92" y="84" width="140" height="272" rx="18" style="--d: 0.35s" />
      <rect class="hl-line" pathLength="1" x="256" y="84" width="372" height="272" rx="18" style="--d: 0.5s" />
      <rect class="hl-line" pathLength="1" x="284" y="112" width="88" height="216" rx="12" style="--d: 0.65s" />
      <rect class="hl-line" pathLength="1" x="392" y="112" width="88" height="216" rx="12" style="--d: 0.75s" />
      <rect class="hl-line" pathLength="1" x="500" y="112" width="88" height="216" rx="12" style="--d: 0.85s" />
      <!-- 尺寸标注线：工程图纸的小回声 -->
      <path class="hl-line hl-dim" pathLength="1" d="M64 404v8M64 408h592M656 404v8" style="--d: 1.05s" />
    </g>

    <!-- 角部对位十字 -->
    <g class="hl-marks">
      <path d="M40 30v20M30 40h20" />
      <path d="M680 390v20M670 400h20" />
    </g>

    <!-- 光标像素：画完后开始眨 -->
    <rect class="hl-cursor" x="114" y="106" width="8" height="14" />
  </svg>
</div>
