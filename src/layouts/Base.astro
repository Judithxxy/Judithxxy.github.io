---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Icon from '../components/Icon.astro';
import { t, LOCALES, type Locale } from '../i18n';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  locale?: Locale;
  // Locale-less path of this page (e.g. "/", "/about/", "/p/granola/") for language alternates
  pagePath?: string;
  // Keep utility pages (404) out of the index
  noindex?: boolean;
}

const { title, description, ogImage, ogType = 'website', locale = 'en', pagePath, noindex = false } =
  Astro.props;
const s = t[locale];
const current = LOCALES.find((l) => l.code === locale)!;
const path =
  pagePath ??
  Astro.url.pathname.replace(/^\/(zh|ja)(?=\/|$)/, '').replace(/^$/, '/');
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImageAbs = ogImage ? new URL(ogImage, Astro.site).href : undefined;

// og:locale 用下划线格式；alternate 列出其余两个语言
const ogLocale: Record<Locale, string> = { en: 'en_US', zh: 'zh_CN', ja: 'ja_JP' };
const ogLocaleAlternates = LOCALES.filter((l) => l.code !== locale).map((l) => ogLocale[l.code]);
---

<!doctype html>
<html lang={current.lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {
      noindex ? (
        <meta name="robots" content="noindex, follow" />
      ) : (
        <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
      )
    }
    <link rel="canonical" href={canonical} />
    {
      LOCALES.map((l) => (
        <link rel="alternate" hreflang={l.lang} href={new URL(`${l.prefix}${path}`, Astro.site)} />
      ))
    }
    <link rel="alternate" hreflang="x-default" href={new URL(path, Astro.site)} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Actually Good" />
    <meta property="og:locale" content={ogLocale[locale]} />
    {ogLocaleAlternates.map((l) => <meta property="og:locale:alternate" content={l} />)}
    {ogImageAbs && <meta property="og:image" content={ogImageAbs} />}
    {ogImageAbs && <meta property="og:image:alt" content={title} />}
    <meta name="twitter:card" content={ogImageAbs ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImageAbs && <meta name="twitter:image" content={ogImageAbs} />}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title="Actually Good" href="/rss.xml" />
    <link rel="preload" href="/fonts/instrument-sans-var.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/instrument-serif.woff2" as="font" type="font/woff2" crossorigin />
    <ClientRouter />
  </head>
  <body>
    <div class="wrap">
      <header class="topbar">
        <a href={`${current.prefix}/`} class="brand" aria-label="Actually Good.">actually good<span class="brand-dot">.</span></a>
        <div class="topbar-right">
          <nav>
            <a href={`${current.prefix}/#index`}>{s.navIndex}</a>
            <a href={`${current.prefix}/about/`}>{s.navAbout}</a>
          </nav>
          <div class="lang-menu">
            <button class="lang-btn" type="button" aria-haspopup="true" aria-expanded="false" aria-label="Language">
              {LOCALES.find((l) => l.code === locale)!.label}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6" /></svg>
            </button>
            <div class="lang-pop" hidden>
              {
                LOCALES.map((l) => (
                  <a
                    class={l.code === locale ? 'lang-item on' : 'lang-item'}
                    href={`${l.prefix}${path}`}
                    lang={l.lang}
                    data-lang={l.code}
                    aria-current={l.code === locale ? 'page' : undefined}
                  >
                    {l.label}
                  </a>
                ))
              }
            </div>
          </div>
        </div>
      </header>
      <slot />
      <footer>
        <div class="foot-brand">
          <span class="f-brand">actually good<span class="brand-dot">.</span></span>
          <p class="foot-slogan">{s.slogan}</p>
        </div>
        <p class="foot-meta">
          <a class="rss-inline" href="/rss.xml"><Icon name="rss" /> {s.subscribeRss}</a>
          <span class="foot-sep">·</span> © 2026 Actually Good — {s.footerNote}
        </p>
      </footer>
    </div>
    <script is:inline>
      (function () {
        var KEY = 'considered-locale';
        function localeOf(p) {
          var m = p.match(/^\/(zh|ja)(?=\/|$)/);
          return m ? m[1] : 'en';
        }
        function pathIn(p, target) {
          var bare = p.replace(/^\/(zh|ja)(?=\/|$)/, '') || '/';
          return (target === 'en' ? '' : '/' + target) + bare;
        }
        // First visit on a default-language page: follow the browser language.
        // Landing directly on /zh/ or /ja/ is treated as explicit intent — never hijacked.
        try {
          if (!localStorage.getItem(KEY) && localeOf(location.pathname) === 'en') {
            var nav = (navigator.language || '').toLowerCase();
            var want = nav.indexOf('zh') === 0 ? 'zh' : nav.indexOf('ja') === 0 ? 'ja' : 'en';
            localStorage.setItem(KEY, want);
            if (want !== 'en') {
              location.replace(pathIn(location.pathname, want));
              return;
            }
          }
        } catch (e) {}
        function bind() {
          var btn = document.querySelector('.lang-btn');
          var pop = document.querySelector('.lang-pop');
          if (!btn || !pop) return;
          function close() {
            pop.hidden = true;
            btn.setAttribute('aria-expanded', 'false');
          }
          btn.onclick = function (e) {
            e.stopPropagation();
            var open = pop.hidden;
            pop.hidden = !open;
            btn.setAttribute('aria-expanded', String(open));
          };
          document.onclick = function () { close(); };
          document.onkeydown = function (e) { if (e.key === 'Escape') close(); };
          var items = pop.querySelectorAll('.lang-item');
          for (var i = 0; i < items.length; i++) {
            items[i].onclick = function () {
              try {
                localStorage.setItem(KEY, this.getAttribute('data-lang'));
              } catch (e) {}
            };
          }
        }
        bind();
        document.addEventListener('astro:page-load', bind);
      })();
    </script>
  </body>
</html>
